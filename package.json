{
	"name": "mybbbridge-modern",
	"displayName": "MyBBBridge Modern",
	"description": "Visual Studio Code extension aimed at making MyBB theme development more convenient.",
	"version": "0.1.0",
	"publisher": "Mivvie",
	"repository": {
		"type": "git",
		"url": "https://github.com/Mivvie/MyBBBridge-Modern.git"
	},
	"engines": {
		"vscode": "^1.109.0"
		
	},
	"categories": [
		"Other"
	],
	"preview": true,
	"activationEvents": [
		"workspaceContains:.vscode/mbbbm.json"
	],
	"main": "./out/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "extension.createConfig",
				"title": "MyBBBridge Modern: Set up."
			},
			{
				"command": "extension.addTheme",
				"title": "MyBBBridge Modern: Add theme from database."
			}
		]
	},
	"scripts": {
		"vscode:prepublish": "npm run compile",
		"compile": "tsc -p ./",
		"watch": "tsc -watch -p ./",
		"pretest": "npm run compile",
		"test": "node ./out/test/runTest.js"
	},
	"devDependencies": {
		"@types/glob": "^7.1.1",
		"@types/mocha": "^5.2.7",
		"@types/node": "^12.11.7",
		"@types/vscode": "^1.41.0",
		"glob": "^7.1.5",
		"mocha": "^6.2.2",
		"typescript": "^3.6.4",
		"tslint": "^5.20.0",
		"vscode-test": "^1.2.2"
	},
	"dependencies": {
		"@types/mysql": "^2.15.8",
		"@types/request-promise-native": "^1.0.17",
		"mysql": "^2.17.1",
		"request": "^2.88.0",
		"request-promise-native": "^1.0.8"
	}
}
